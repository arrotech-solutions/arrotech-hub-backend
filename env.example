# =============================================================================
# Mini-Hub Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env files to version control!

# =============================================================================
# Application Configuration
# =============================================================================
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1

# =============================================================================
# Database Configuration
# =============================================================================
DATABASE_URL=postgresql://minihub:password@postgres:5432/minihub
POSTGRES_DB=minihub
POSTGRES_USER=minihub
POSTGRES_PASSWORD=password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# =============================================================================
# Celery Configuration (Task Queue)
# =============================================================================
# Broker (task message queue) — uses Redis DB 1 (separate from cache DB 0)
CELERY_BROKER_URL=redis://redis:6379/1
# Result backend (task result storage) — uses Redis DB 2
CELERY_RESULT_BACKEND=redis://redis:6379/2
# Worker settings
CELERY_TASK_TIME_LIMIT=300
CELERY_TASK_SOFT_TIME_LIMIT=240
CELERY_WORKER_MAX_TASKS_PER_CHILD=100
CELERY_WORKER_CONCURRENCY=4
# Flower monitoring dashboard (http://localhost:5555)
CELERY_FLOWER_PORT=5555
CELERY_FLOWER_BASIC_AUTH=admin:changeme

# =============================================================================
# LLM Configuration
# =============================================================================
# Provider options: ollama, openai, anthropic, gemini, huggingface, togetherai
DEFAULT_LLM_PROVIDER=openai
LLM_TEMPERATURE=0.7

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# Ollama Configuration (for local models)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2:3b

# Anthropic Configuration
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# =============================================================================
# M-Pesa Configuration (Safaricom)
# =============================================================================
MPESA_CONSUMER_KEY=your_mpesa_consumer_key_here
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret_here
MPESA_PASSKEY=your_mpesa_passkey_here
MPESA_BUSINESS_SHORT_CODE=174379
MPESA_ENVIRONMENT=sandbox
MPESA_CALLBACK_URL=https://your-domain.ngrok-free.app/api/mpesa/callback

# =============================================================================
# Stripe Configuration
# =============================================================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here
STRIPE_API_VERSION=2023-10-16

# =============================================================================
# HubSpot Configuration
# =============================================================================
HUBSPOT_API_KEY=your_hubspot_api_key_here
HUBSPOT_CLIENT_ID=your_hubspot_client_id_here
HUBSPOT_CLIENT_SECRET=your_hubspot_client_secret_here

# =============================================================================
# Slack Configuration
# =============================================================================
SLACK_BOT_TOKEN=xoxb-your_slack_bot_token_here
SLACK_SIGNING_SECRET=your_slack_signing_secret_here
SLACK_CLIENT_ID=your_slack_client_id_here
SLACK_CLIENT_SECRET=your_slack_client_secret_here

# =============================================================================
# WhatsApp Business API Configuration
# =============================================================================
WHATSAPP_BASE_URL=https://graph.facebook.com/v22.0
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here
WHATSAPP_BUSINESS_ACCOUNT_ID=your_whatsapp_business_account_id_here
WHATSAPP_TOKEN=your_whatsapp_token_here
WHATSAPP_VERIFY_TOKEN=your_whatsapp_verify_token_here

# =============================================================================
# Asana Configuration
# =============================================================================
ASANA_ACCESS_TOKEN=your_asana_access_token_here
ASANA_WORKSPACE_ID=your_asana_workspace_id_here

# =============================================================================
# Power BI Configuration
# =============================================================================
POWERBI_CLIENT_ID=your_powerbi_client_id_here
POWERBI_CLIENT_SECRET=your_powerbi_client_secret_here
POWERBI_TENANT_ID=your_powerbi_tenant_id_here

# =============================================================================
# Google Services Configuration
# =============================================================================
GEMINI_API_KEY=your_gemini_api_key_here
GA4_PROPERTY_ID=your_ga4_property_id_here
GA4_CREDENTIALS_FILE=your_credentials_file
GOOGLE_APPLICATION_CREDENTIALS=your_credentials_file

# =============================================================================
# Security Configuration
# =============================================================================
SECRET_KEY=your_django_secret_key_here
JWT_SECRET_KEY=your_jwt_secret_key_here
ENCRYPTION_KEY=your_encryption_key_here

# =============================================================================
# External Services Configuration
# =============================================================================
NGROK_AUTH_TOKEN=your_ngrok_auth_token_here
SENTRY_DSN=your_sentry_dsn_here

# =============================================================================
# Feature Flags
# =============================================================================
ENABLE_MPESA=true
ENABLE_STRIPE=true
ENABLE_HUBSPOT=true
ENABLE_SLACK=true
ENABLE_WHATSAPP=true
ENABLE_GA4=true
ENABLE_GEMINI=true
ENABLE_ASANA=true
ENABLE_POWERBI=true
ENABLE_OUTLOOK=true
ENABLE_NOTION=true
ENABLE_TRELLO=true
ENABLE_JIRA=true
ENABLE_TEAMS=true
ENABLE_ZOOM=true

# =============================================================================
# Microsoft Outlook Configuration
# =============================================================================
OUTLOOK_CLIENT_ID=your_outlook_client_id_here
OUTLOOK_CLIENT_SECRET=your_outlook_client_secret_here
OUTLOOK_REDIRECT_URI=http://localhost:8000/api/outlook/callback

# =============================================================================
# Notion Configuration
# =============================================================================
NOTION_CLIENT_ID=your_notion_client_id_here
NOTION_CLIENT_SECRET=your_notion_client_secret_here
NOTION_REDIRECT_URI=http://localhost:8000/api/notion/callback

# =============================================================================
# Trello Configuration
# =============================================================================
TRELLO_CLIENT_ID=your_trello_client_id_here
TRELLO_CLIENT_SECRET=your_trello_client_secret_here
TRELLO_REDIRECT_URI=http://localhost:8000/api/trello/callback

# =============================================================================
# Jira Configuration
# =============================================================================
JIRA_CLIENT_ID=your_jira_client_id_here
JIRA_CLIENT_SECRET=your_jira_client_secret_here
JIRA_REDIRECT_URI=http://localhost:8000/api/jira/callback

# =============================================================================
# Microsoft Teams Configuration
# =============================================================================
TEAMS_WEBHOOK_URL=your_teams_webhook_url_here
TEAMS_TENANT_ID=your_teams_tenant_id_here
TEAMS_CLIENT_ID=your_teams_client_id_here
TEAMS_CLIENT_SECRET=your_teams_client_secret_here
TEAMS_REDIRECT_URI=http://localhost:8000/api/teams/callback

# =============================================================================
# Zoom Configuration
# =============================================================================
ZOOM_CLIENT_ID=your_zoom_client_id_here
ZOOM_CLIENT_SECRET=your_zoom_client_secret_here
ZOOM_ACCOUNT_ID=your_zoom_account_id_here
ZOOM_REDIRECT_URI=http://localhost:8000/api/zoom/callback

# =============================================================================
# Xero Configuration
# =============================================================================
XERO_CLIENT_ID=your_xero_client_id_here
XERO_CLIENT_SECRET=your_xero_client_secret_here
XERO_REDIRECT_URI=http://localhost:8000/api/xero/callback

# =============================================================================
# Email / SMTP Configuration (Zoho Mail)
# =============================================================================
SMTP_HOST=smtppro.zoho.com
SMTP_PORT=465
SMTP_USER=noreply@arrotechsolutions.com
SMTP_PASSWORD=your_zoho_password_here
FROM_EMAIL=noreply@arrotechsolutions.com
FROM_NAME=Arrotech Hub

# Support email (separate Zoho account for support tickets)
SUPPORT_EMAIL_PASSWORD=your_zoho_support_password_here
SUPPORT_SMTP_USER=support@arrotechsolutions.com

# Resend API (backup transport — uncomment if SMTP is blocked by hosting provider)
# RESEND_API_KEY=re_your_resend_api_key_here

# =============================================================================
# Development Configuration
# =============================================================================
# Set to true for development, false for production
ENABLE_DEBUG_TOOLBAR=false
ENABLE_SQL_LOGGING=false
ENABLE_REQUEST_LOGGING=true 