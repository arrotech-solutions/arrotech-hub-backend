# =============================================================================
# Arrotech Hub — Production Environment Variables
# =============================================================================
# INSTRUCTIONS:
#   1. Copy this file to .env.production on the EC2 server
#   2. Replace ALL <PLACEHOLDER> values with real credentials
#   3. NEVER commit the filled-in .env.production to version control
#   4. Generate strong passwords with: openssl rand -base64 32
# =============================================================================

# ── Database ────────────────────────────────────────────────────────────────
# Uses internal Docker network hostname "postgres"
DATABASE_URL=postgresql://minihub:<DB_PASSWORD_HERE>@postgres:5432/minihub
POSTGRES_DB=minihub
POSTGRES_USER=minihub
POSTGRES_PASSWORD=<DB_PASSWORD_HERE>
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Redis ───────────────────────────────────────────────────────────────────
# Uses internal Docker network hostname "redis"
REDIS_PASSWORD=<REDIS_PASSWORD_HERE>
REDIS_URL=redis://:<REDIS_PASSWORD_HERE>@redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ── Celery ──────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://:<REDIS_PASSWORD_HERE>@redis:6379/1
CELERY_RESULT_BACKEND=redis://:<REDIS_PASSWORD_HERE>@redis:6379/2
CELERY_TASK_TIME_LIMIT=300
CELERY_TASK_SOFT_TIME_LIMIT=240
CELERY_WORKER_MAX_TASKS_PER_CHILD=100
CELERY_WORKER_CONCURRENCY=2
CELERY_FLOWER_PORT=5555
CELERY_FLOWER_BASIC_AUTH=<FLOWER_USER>:<FLOWER_PASSWORD>

# ── Application ─────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=WARNING
PYTHONUNBUFFERED=1

# ── Security Keys (generate with: openssl rand -hex 64) ────────────────────
SECRET_KEY=<GENERATE_SECRET_KEY>
JWT_SECRET_KEY=<GENERATE_JWT_SECRET>
ENCRYPTION_KEY=<GENERATE_ENCRYPTION_KEY>

# ── URLs ────────────────────────────────────────────────────────────────────
API_BASE_URL=https://prod.api.arrotechsolutions.com
FRONTEND_URL=https://hub.arrotechsolutions.com
ADMIN_FRONTEND_URL=https://admin.arrotechsolutions.com

# ── Admin ───────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=<ADMIN_PASSWORD_HERE>

